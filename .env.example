# Core application settings
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sales_app
# Optional secondary database for Assembly RFQ mirroring
DATABASE_URL2=
SECRET_KEY=replace-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CRON_TOKEN=replace-with-long-random-token

# OpenAI
OPENAI_API_KEY=

# Frontend origins
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=

# Azure Blob Storage
AZURE_CONNECTION_STRING=
AZURE_RFQ_FILES_CONTAINER=rfq-files

# SMTP email delivery
# Current relay config:
SMTP_HOST=avocarbon-com.mail.protection.outlook.com
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=administration.STS@avocarbon.com

# Workspace Agent GPT — AI pre-validation before sending the validator email.
# WORKSPACE_AGENT_TRIGGER_ID is the published API channel id (agtch_...) from Agent Studio.
WORKSPACE_AGENT_TRIGGER_ID=
# AGENT_ACCESS_TOKEN must be a ChatGPT Workspace Agent access token with the
# Workspace Agents scope. Do not reuse OPENAI_API_KEY or a Codex-only token here.
# If left empty, AI validation is skipped (fail-open).
AGENT_ACCESS_TOKEN=
# Shared secret used by your MCP tool to push the final approved/rejected result
# back into this backend.
AI_VALIDATION_CALLBACK_TOKEN=
